{
  "name": "@mergesignal/shared",
  "version": "0.12.3",
  "description": "MergeSignal shared scan contract, presentation policy, and trusted validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MergeSignal/mergesignal.git",
    "directory": "packages/shared"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run generate:ci-copy",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "generate:ci-copy": "tsx scripts/emit-scan-surface-copy.ts",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mergesignal/contracts": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
