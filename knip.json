{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreUnresolved": ["next"],
  "ignoreBinaries": ["eslint", "tsx"],
  "ignoreFiles": [
    "apps/api/eslint.config.js",
    "apps/worker/eslint.config.js",
    "scripts/ci/render-mergesignal-step-summary.mjs",
    "scripts/ci/render-mergesignal-failure-summary.mjs",
    "scripts/ci/audit-trusted-actions-output.mjs",
    "scripts/docker/write-fixture-engine-manifest.mjs"
  ],
  "workspaces": {
    "apps/cli": {
      "ignoreDependencies": ["@mergesignal/engine-test-fixture"]
    },
    "apps/api": {
      "ignoreDependencies": ["@repo/eslint-config"]
    },
    "apps/worker": {
      "ignoreDependencies": [
        "@repo/eslint-config",
        "@mergesignal/engine-test-fixture"
      ]
    },
    "packages/engine": {
      "ignoreDependencies": ["@mergesignal/engine-test-fixture"]
    }
  },
  "ignoreIssues": {
    "apps/api/**": ["exports", "types"],
    "apps/web/**": ["exports", "types"]
  }
}
