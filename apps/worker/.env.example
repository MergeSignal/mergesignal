DATABASE_URL="postgresql://reposentinel:reposentinel@localhost:5433/reposentinel?schema=public"
REDIS_URL="redis://localhost:6379"

# RepoSentinel Web URL (for linking to scan details from PR comments)
REPOSENTINEL_WEB_URL=http://localhost:3000

# GitHub App (for PR comments and webhooks)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Tier Configuration
# REPOSENTINEL_OWNER_TIERS=org1=paid,org2=free
# REPOSENTINEL_DEFAULT_TIER=free

# Free Tier Settings
FREE_PR_COMMENTS_ENABLED=1
FREE_ALERTS_ENABLED=0
FREE_ALERTS_BATCH_LIMIT=5
FREE_ALERTS_CONCURRENCY=1
FREE_ALERTS_MIN_SCORE_IMPACT=12

# PR Comment Verbosity (free tier)
FREE_PR_COMMENT_MAX_FINDINGS=2          # Max findings to show in PR comment
FREE_PR_COMMENT_MAX_ACTIONS=2           # Max action items to show in PR comment
FREE_PR_COMMENT_SHOW_DETAILS_LINK=1     # Show link to full scan details

# Engine Output Limits (free tier) - Keep these SMALL for focused summaries
FREE_ENGINE_MAX_FINDINGS=3              # Max findings in scan result
FREE_ENGINE_MAX_RECOMMENDATIONS=3       # Max recommendations in scan result
FREE_ENGINE_MAX_DEEPEST_DEPS=2          # Max deepest dependencies shown
FREE_ENGINE_MAX_HOTSPOTS=2              # Max hotspot packages shown
FREE_ENGINE_MAX_VULNERABLE=2            # Max vulnerable packages shown

# Paid Tier Settings
# PAID_ALERTS_BATCH_LIMIT=50
# PAID_ALERTS_CONCURRENCY=4
# PAID_ALERTS_MIN_SCORE_IMPACT=8

# PR Comment Verbosity (paid tier)
# PAID_PR_COMMENT_MAX_FINDINGS=3         # Max findings to show in PR comment
# PAID_PR_COMMENT_MAX_ACTIONS=3          # Max action items to show in PR comment
# PAID_PR_COMMENT_SHOW_DETAILS_LINK=1    # Show link to full scan details

# Engine Output Limits (paid tier) - More detailed for paying customers
# PAID_ENGINE_MAX_FINDINGS=5             # Max findings in scan result
# PAID_ENGINE_MAX_RECOMMENDATIONS=5      # Max recommendations in scan result
# PAID_ENGINE_MAX_DEEPEST_DEPS=3         # Max deepest dependencies shown
# PAID_ENGINE_MAX_HOTSPOTS=3             # Max hotspot packages shown
# PAID_ENGINE_MAX_VULNERABLE=3           # Max vulnerable packages shown

# Engine Configuration
# REPOSENTINEL_ENGINE_IMPL=              # Path to proprietary engine (defaults to stub)
# REPOSENTINEL_ENGINE_STRICT=0           # Fail if engine not found (0=fallback to stub)

# Worker Configuration
# SCAN_HEARTBEAT_MS=15000
# SCAN_STALE_AFTER_MS=60000
# SCAN_REAP_INTERVAL_MS=30000
# ALERTS_INTERVAL_MS=3600000
# SCAN_SIMULATE_DELAY_MS=0

# Health Check Thresholds
# REPOSENTINEL_HEALTH_STALE_DAYS=365
# REPOSENTINEL_HEALTH_VERY_STALE_DAYS=730
