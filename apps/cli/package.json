{
  "name": "@mergesignal/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mergesignal": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/cli.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mergesignal/engine": "workspace:^",
    "@mergesignal/shared": "workspace:^"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
